{
  "name": "@lucianfialho/pii-filter",
  "version": "0.1.0",
  "description": "Deterministic PII filtering — redact or pseudonymize personal data in JSON payloads",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["pii", "privacy", "gdpr", "redact", "pseudonymize"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
